# ─────────────────────────────────────────────────────────────
# areadev-infra-2026 — Environment Variables
# Copy to .env and fill in values
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL (PostGIS 16) ──────────────────────────────────
POSTGRES_USER=directus
POSTGRES_PASSWORD=directus
POSTGRES_DB=directus

# ── MSSQL Server 2019 ───────────────────────────────────────
MSSQL_SA_PASSWORD=YourStrongPassword123

# ── Redis ────────────────────────────────────────────────────
# No additional config needed for local dev

# ── LocalStack (AWS emulation) ───────────────────────────────
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ── ETL Cron ────────────────────────────────────────────────
# Cron schedule for incremental sync (default: every 6 hours)
SYNC_CRON_SCHEDULE=0 */6 * * *
ETL_API_TOKEN=
DEFAULT_DIRECTUS_USER=

# ── Directus CMS ────────────────────────────────────────────
SECRET=change-me-in-production
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=d1r3ctu5
DIRECTUS_URL=http://localhost:8055

# Directus S3 Storage (points to LocalStack)
STORAGE_S3_DEV1_KEY=test
STORAGE_S3_DEV1_SECRET=test
STORAGE_S3_DEV1_ENDPOINT=http://infra-localstack:4566
STORAGE_S3_DEV1_REGION=us-east-1
STORAGE_S3_DEV1_BUCKET=areadev-directus-storage-dev-1
STORAGE_S3_DEV1_FORCE_PATH_STYLE=true

# ── API ──────────────────────────────────────────────────────
API_PORT=8000
API_DB_HOST=localhost
API_DB_PORT=5432
API_DB_USER=directus
API_DB_PASSWORD=directus
API_DB_NAME=directus

# ── Frontend ─────────────────────────────────────────────────
NUXT_PUBLIC_API_BASE=http://localhost:8000/api/v1
NUXT_PUBLIC_DIRECTUS_URL=http://localhost:8055
NUXT_PUBLIC_DIRECTUS_ASSETS=http://localhost:8055/assets

# ── Third-party keys (optional for local dev) ───────────────
DATAWRAPPER_API_KEY=
VIMEO_CLIENT_SECRET=
VIMEO_CLIENT_ID=
VIMEO_TOKEN=
OPENAI_API_KEY=
